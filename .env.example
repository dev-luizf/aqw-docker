# Copy to .env and adjust:
#   cp .env.example .env
#
# Start:
#   docker compose up -d --build
# Play (Ruffle in browser):
#   http://127.0.0.1:8081/play.php
#
# Default host port is 8081 (avoids clash with project-azdana on 8080).

# Host port for CMS + Ruffle WebSocket proxy
WEB_PORT_HOST=8081

# SmartFox game TCP port (inside compose network)
GAME_PORT=5588

# Hostname the Ruffle proxy uses to dial the game container
AQW_GAME_HOST=game

# IP returned to Flash/Ruffle in login XML (must match Ruffle socketProxy host)
PUBLIC_GAME_IP=127.0.0.1
SERVER_NAME=Armagedom
GAME_SERVER_MAX_PLAYERS=900
# 0 = canned chat, 1 = safe chat, 2 = normal chat
GAME_SERVER_CHAT_MODE=2
GAME_SERVER_UPGRADE_ONLY=0
GAME_SERVER_MOTD=Welcome to Armagedom!

SITE_NAME=Armagedom Worlds
SITE_COMPANY=Armagedom Team
SITE_DESCRIPTION=AQW private server powered by Armagedom V2

# Client stack. These values are the source of truth for the website, loaders,
# login responses, game menu, emulator compatibility tables, and server list.
GAME_LOADER=/gamefiles/loaders/Loader_Spider.swf
GAME_CLIENT_SWF=spider.swf
GAME_CLIENT_TITLE=Armagedom Worlds
GAME_CLIENT_BG=Back.swf
GAME_CLIENT_VERSION=ARM001
GAME_VERSION_STATUS=success

# Client UI and assets (paths are relative to /gamefiles unless noted).
# Leave GAME_MENU empty to skip the in-game AWMenu.
# A bare menu filename is automatically prefixed with gameMenu/.
GAME_MENU=
GAME_ASSETS=AWAssets.swf
GAME_NEWS=
GAME_MAP=news/Map-UI_r38.swf
GAME_BOOK=news/spiderbook3.swf
GAME_FBC=FBC-2011-03-08.swf
GAME_NEW_USER=newuser/AQW-Landing-r6.swf

# Client/account limits
GAME_MAX_BAG_SLOTS=500
GAME_MAX_BANK_SLOTS=900
GAME_MAX_HOUSE_SLOTS=300
GAME_MAX_GUILD_MEMBERS=800
GAME_MAX_FRIENDS=300
GAME_MAX_LOADOUT_SLOTS=50

TIMEZONE=UTC

MYSQL_ROOT_PASSWORD=armagedom
MYSQL_DATABASE=mextv3
MYSQL_USER=aqw
MYSQL_PASSWORD=aqw
MYSQL_PORT=3306

SFS_ADMIN_USER=dolphin
SFS_ADMIN_PASSWORD=test123
