RewriteEngine On

# Compatibility redirects for links shipped with the legacy CMS. Linux paths are
# case-sensitive, while the original site was authored with mixed-case names.
RewriteRule ^Char\.php$ /char.php [R=301,L,NE]
RewriteRule ^TPvPRanking\.php$ /TPVPRanking.php [R=301,L,NE]

# Flash clients historically hit .asp endpoints â€” run them as PHP
AddType application/x-httpd-php .asp .php

# Loader always requests gameversion.asp; serve the URL-encoded responder.
RewriteRule ^getversion\.asp$ gameversion2.php [L,QSA]
RewriteRule ^gameversion\.asp$ gameversion2.php [L,QSA]
RewriteRule ^gameversion2\.asp$ gameversion2.php [L,QSA]
RewriteRule ^cf-userlogin\.asp$ cf-userlogin.php [L,QSA]
RewriteRule ^cf-usersignup\.asp$ cf-usersignup.php [L,QSA]
RewriteRule ^travelmap\.asp$ travelmap.php [L,QSA]

# Azdana-style /game/ base URL (game_port_* clients call http://host:port/game/...)
RewriteRule ^game/cf-userlogin\.asp$ cf-userlogin.php [L,QSA]
RewriteRule ^game/cf-userlogin\.php$ cf-userlogin.php [L,QSA]
RewriteRule ^game/cf-usersignup\.asp$ cf-usersignup.php [L,QSA]
RewriteRule ^game/cf-usersignup\.php$ cf-usersignup.php [L,QSA]
RewriteRule ^game/getversion\.asp$ gameversion2.php [L,QSA]
RewriteRule ^game/gameversion\.asp$ gameversion2.php [L,QSA]
RewriteRule ^game/crossdomain\.xml$ crossdomain.xml [L]
RewriteRule ^game/quest\.asp$ quest.php [L,QSA]
RewriteRule ^quest\.asp$ quest.php [L,QSA]

# Spider / modern JSON APIs (Loader_Spider, spider.swf, AQLite).
RewriteRule ^api/data/gameversion$ api/data/gameversion.php [L,QSA]
RewriteRule ^api/data/servers$ api/data/servers.php [L,QSA]
RewriteRule ^api/data/clientvars$ api/data/clientvars.php [L,QSA]
RewriteRule ^api/data/travelmap$ api/data/travelmap.php [L,QSA]
RewriteRule ^api/login/now$ api/login/now.php [L,QSA]
RewriteRule ^game/api/login/now$ api/login/now.php [L,QSA]
RewriteRule ^game/api/data/gameversion$ api/data/gameversion.php [L,QSA]
RewriteRule ^game/api/data/servers$ api/data/servers.php [L,QSA]
RewriteRule ^game/api/data/clientvars$ api/data/clientvars.php [L,QSA]
RewriteRule ^game/api/data/travelmap$ api/data/travelmap.php [L,QSA]
RewriteRule ^standalone/api/data/gameversion$ api/data/gameversion.php [L,QSA]
RewriteRule ^game/standalone/api/data/gameversion$ api/data/gameversion.php [L,QSA]
RewriteRule ^gamefiles/standalone/api/data/gameversion$ api/data/gameversion.php [L,QSA]
RewriteRule ^gamefiles/api/data/gameversion$ api/data/gameversion.php [L,QSA]

# SWF base URL is often /gamefiles/ â€” mirror root Flash endpoints there.
RewriteRule ^gamefiles/cf-userlogin\.asp$ cf-userlogin.php [L,QSA]
RewriteRule ^gamefiles/cf-userlogin\.php$ cf-userlogin.php [L,QSA]
RewriteRule ^gamefiles/loaders/api/login/now$ api/login/now.php [L,QSA]
RewriteRule ^gamefiles/cf-usersignup\.asp$ cf-usersignup.php [L,QSA]
RewriteRule ^gamefiles/travelmap\.asp$ travelmap.php [L,QSA]
RewriteRule ^gamefiles/gameversion\.asp$ gameversion2.php [L,QSA]

# Case-insensitive fallback for missing gamefiles assets (Linux).
# Internal rewrite â€” no redirect â€” so Ruffle/Flash keep the original URL.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-l
RewriteCond %{REQUEST_URI} !/gamefiles/casefix\.php
RewriteRule ^gamefiles/.+ gamefiles/casefix.php [L,QSA]

# Avoid caching SWFs while iterating on a private server
<FilesMatch "\.(swf|xml)$">
  Header set Cache-Control "no-store, no-cache, must-revalidate"
  Header set Pragma "no-cache"
</FilesMatch>
