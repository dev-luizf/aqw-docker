{
  "name": "armagedom-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare:ruffle": "node scripts/copy-ruffle.mjs",
    "predev": "node scripts/copy-ruffle.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/copy-ruffle.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "docker:build": "docker compose build",
    "docker:rebuild": "docker compose build --no-cache",
    "docker:up": "docker compose up --build --detach",
    "docker:down": "docker compose down --remove-orphans",
    "docker:restart": "docker compose restart",
    "docker:logs": "docker compose logs --follow --tail=200",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.23",
    "@radix-ui/react-slot": "1.2.4",
    "@ruffle-rs/ruffle": "0.4.0-nightly.2026.7.18",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "gray-matter": "4.0.3",
    "lucide-react": "0.468.0",
    "mysql2": "3.15.3",
    "next": "16.2.10",
    "nodemailer": "7.0.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.0",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.18",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "24.10.1",
    "@types/nodemailer": "7.0.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.1.18",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.15"
  },
  "packageManager": "pnpm@10.28.1"
}
